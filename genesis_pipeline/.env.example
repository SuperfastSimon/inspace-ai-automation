# Set the key for whichever provider you use (others optional)

# Anthropic (default provider)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Google Gemini
GOOGLE_API_KEY=AIza...

# Jina (optional — improves web search rate limits)
JINA_API_KEY=jina_...

# SMTP — if omitted, report saves as HTML file locally
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=you@gmail.com
